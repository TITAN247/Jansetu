# JanSetu AI Configuration
# Copy this file to .env and update the values

# MongoDB Atlas Connection
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/jansetu_ai?retryWrites=true&w=majority

# JWT Secret Key (generate a random string)
SECRET_KEY=your-secret-key-here-change-this-in-production

# JanSetu AI Email Configuration
# Get Gmail App Password: Google Account > Security > 2-Step Verification > App Passwords
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
